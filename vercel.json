{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/admin",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "en.lapiccolaperla.cz"
        }
      ],
      "destination": "https://lapiccolaperla.cz/en",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "it.lapiccolaperla.cz"
        }
      ],
      "destination": "https://lapiccolaperla.cz/it",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "cs.lapiccolaperla.cz"
        }
      ],
      "destination": "https://lapiccolaperla.cz/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.lapiccolaperla.cz"
        }
      ],
      "destination": "https://lapiccolaperla.cz/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "lapiccolaperla.vercel.app"
        }
      ],
      "destination": "https://lapiccolaperla.cz/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/en",
      "destination": "/en.html"
    },
    {
      "source": "/it",
      "destination": "/it.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
